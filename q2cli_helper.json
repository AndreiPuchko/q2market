   "action_worker": "# subprocess.Popen([\"powershell\", \"-NoExit\", \"ls\"], creationflags=subprocess.CREATE_NEW_CONSOLE, cwd = form.r.wd )\r\n# import pathlib\r\n# subprocess.Popen([pathlib.Path(form.r.app_name)],cwd = pathlib.Path(form.r.wd), creationflags=subprocess.CREATE_NEW_CONSOLE)\r\nargs = [form.r.app_name]\r\nif _args := [x['arg'] for x in q2cursor(f\"\"\"select arg \r\n                                                                from args \r\n                                                                where parent_id = {form.r.id} \r\n                                                                    and deactivated = ''\r\n                                                                order by seq\"\"\").records()]:\r\n    args.extend(_args)\r\n    # q2mess(args)\r\n    \r\ncreationflags=subprocess.CREATE_NEW_CONSOLE\r\nshell = False\r\nimport shutil\r\nif not shutil.which(args[0]):\r\n    args.insert(0, \"-NoExit\")\r\n    args.insert(0, \"powershell\")\r\n    \r\nif form.r.hide_console:\r\n    creationflags = 0\r\n    shell = True\r\n\r\nsubprocess.Popen(args, cwd = (form.r.wd if form.r.wd  else \".\"), creationflags=creationflags, shell=shell)",
